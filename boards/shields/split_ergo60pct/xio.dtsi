        compatible = "avago,apds9960";

        reg = <0x39>;

        status = "okay";

        int-gpios = <&gpio0 28 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

    };

};
*/


&pwm1 {
    status = "okay";
    pinctrl-0 = <&pwm1_default>;
    pinctrl-names = "default";
};
